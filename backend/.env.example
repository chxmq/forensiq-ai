# Forensiq AI — environment configuration
# Copy to backend/.env and adjust for your deployment.

# ── Server ────────────────────────────────────────────────────────
PORT=8000
FORENSIQ_ENVIRONMENT=development
FORENSIQ_STATIC_DIR=

# ── Authentication (underwriter login) ──────────────────────────
# Set FORENSIQ_AUTH_ENABLED=false only for local dev without login.
FORENSIQ_AUTH_ENABLED=true
FORENSIQ_AUTH_USERNAME=underwriter
FORENSIQ_AUTH_PASSWORD=forensiq
FORENSIQ_AUTH_SECRET=change-me-to-a-long-random-string-in-production

# ── Upload limits ───────────────────────────────────────────────
FORENSIQ_MAX_UPLOAD_BYTES=26214400
FORENSIQ_MAX_UPLOAD_FILES=20

# ── Database ────────────────────────────────────────────────────
# FORENSIQ_DATABASE_URL=sqlite:///./forensiq.db

# ── Seeding ─────────────────────────────────────────────────────
# FORENSIQ_SEED_RESET=true   # force wipe + reseed (scripts.seed only)
